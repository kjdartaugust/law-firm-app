# Supabase — get these from your Supabase project settings (API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key for admin actions (NEVER expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for redirect URLs in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional integrations (the app runs fine without these) ---------------

# Stripe — enables real invoice payments via Checkout. Without these keys the
# "Pay now" button falls back to a simulated payment.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend — enables transactional email (appointment + invoice notifications).
# Without RESEND_API_KEY, email sends are silently skipped.
RESEND_API_KEY=
EMAIL_FROM="Sterling & Crane <onboarding@resend.dev>"
